<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>ESP32 MQTT Web 監控</title>

<!-- MQTT.js -->
<script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>

<style>
body {
  font-family: "Microsoft JhengHei", sans-serif;
  background:#0f172a;
  color:#e5e7eb;
  text-align:center;
}
h1 { color:#38bdf8; }
.card {
  background:#020617;
  border-radius:14px;
  padding:20px;
  margin:20px auto;
  width:320px;
  box-shadow:0 0 20px #38bdf8;
}
.value {
  font-size:36px;
  margin:10px;
}
button {
  font-size:18px;
  padding:10px 28px;
  margin:10px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}
.on { background:#22c55e; }
.off { background:#ef4444; }
.status {
  margin-top:10px;
  font-size:18px;
  color:#facc15;
}
</style>
</head>

<body>

<h1>🌐 ESP32 遠端溫濕度監控</h1>

<div class="card">
  <h2>🌡 溫度</h2>
  <div class="value"><span id="temp">--</span> °C</div>

  <h2>💧 濕度</h2>
  <div class="value"><span id="hum">--</span> %</div>
</div>

<div class="card">
  <h2>💡 LED 控制</h2>
  <button class="on" onclick="setLED(1)">ON</button>
  <button class="off" onclick="setLED(0)">OFF</button>
  <div class="status">狀態：<span id="led">--</span></div>
</div>

<script>
/* ========= MQTT WebSocket 設定 ========= */
const broker = "wss://broker.hivemq.com:8884/mqtt";
const options = {
  clientId: "web_" + Math.random().toString(16).substr(2, 8)
};

const client = mqtt.connect(broker, options);

/* ========= 連線成功 ========= */
client.on("connect", () => {
  console.log("✅ MQTT 已連線");
  client.subscribe("esp32/data");
});

/* ========= 接收資料 ========= */
client.on("message", (topic, message) => {
  console.log("📩", topic, message.toString());

  if (topic === "esp32/data") {
    try {
      const data = JSON.parse(message.toString());

      document.getElementById("temp").innerText = data.temp ?? "--";
      document.getElementById("hum").innerText  = data.hum ?? "--";
      document.getElementById("led").innerText  = data.led == 1 ? "ON" : "OFF";

    } catch (e) {
      console.error("JSON 解析失敗", e);
    }
  }
});

/* ========= LED 控制 ========= */
function setLED(state) {
  client.publish("esp32/led/set", state.toString());
}
</script>

</body>
</html>
