<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <title>ESP32 控制台</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding-top: 50px; background: #f0f0f0; }
        .card { background: white; padding: 20px; display: inline-block; border-radius: 10px; shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .val { font-size: 24px; font-weight: bold; color: blue; }
        #ledBtn { padding: 10px 20px; font-size: 18px; cursor: pointer; margin-top: 20px; }
    </style>
</head>
<body>

    <div class="card">
        <h1>ESP32 DHT11 控制頁面</h1>
        <p>溫度: <span id="temp" class="val">--</span> ℃</p>
        <p>濕度: <span id="hum" class="val">--</span> %</p>
        <button id="ledBtn">讀取資料中...</button>
        <p id="msg" style="color:red; font-size:12px;"></p>
    </div>

    <script>
        // 1. 這裡請務必更換為你「部署後」的完整網址
        const GAS_URL = "https://script.google.com/macros/s/AKfycbwtAjS3gfASvGL1nRwmjhPmNFcRMu1LwvgBRe8485M-pwyPJHLWXiDfEbgwGWVb8SBz/exec"; 

        async function fetchData() {
            const tempEl = document.getElementById("temp");
            const humEl = document.getElementById("hum");
            const btnEl = document.getElementById("ledBtn");
            const msgEl = document.getElementById("msg");

            try {
                const res = await fetch(GAS_URL);
                if (!res.ok) throw new Error('網路回應不正確');
                
                const data = await res.json();
                console.log("成功取得資料:", data);

                tempEl.innerText = data.temp;
                humEl.innerText = data.hum;
                btnEl.innerText = (data.led == 1) ? "關閉 LED" : "開啟 LED";
                btnEl.style.backgroundColor = (data.led == 1) ? "#ffcccc" : "#ccffcc";
                msgEl.innerText = ""; // 清除錯誤訊息
            } catch (error) {
                console.error("抓取失敗:", error);
                msgEl.innerText = "連線失敗: " + error.message;
            }
        }

        // 綁定按鈕點擊事件
        document.getElementById("ledBtn").addEventListener("click", async () => {
            const btn = document.getElementById("ledBtn");
            const isOn = btn.innerText === "關閉 LED";
            const nextState = isOn ? 0 : 1;
            
            btn.innerText = "傳送中...";
            try {
                await fetch(`${GAS_URL}?led=${nextState}`);
                fetchData(); // 傳送完重新整理數值
            } catch (e) {
                alert("切換失敗");
                fetchData();
            }
        });

        // 啟動時先跑一次
        fetchData();
        // 每 5 秒自動更新
        setInterval(fetchData, 5000);
    </script>
</body>
</html>
