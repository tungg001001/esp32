<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>ESP32 MQTT Web Dashboard</title>

<!-- MQTT.js -->
<script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>

<style>
body {
  font-family: "Microsoft JhengHei", sans-serif;
  background:#0f172a;
  color:#e5e7eb;
  text-align:center;
}
.card {
  background:#020617;
  border-radius:12px;
  padding:20px;
  margin:20px auto;
  width:300px;
  box-shadow:0 0 20px #38bdf8;
}
h1 { color:#38bdf8; }
.value { font-size:32px; margin:10px; }
button {
  font-size:18px;
  padding:10px 25px;
  margin:10px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}
.on { background:#22c55e; }
.off { background:#ef4444; }
</style>
</head>

<body>
<h1>🌐 ESP32 遠端監控</h1>

<div class="card">
  <h2>🌡 溫度</h2>
  <div class="value"><span id="temp">--</span> °C</div>

  <h2>💧 濕度</h2>
  <div class="value"><span id="hum">--</span> %</div>
</div>

<div class="card">
  <h2>💡 LED 控制</h2>
  <button class="on" onclick="setLED('on')">ON</button>
  <button class="off" onclick="setLED('off')">OFF</button>
  <p>狀態：<span id="ledState">--</span></p>
</div>

<script>
/* ===== MQTT WebSocket 設定 ===== */
const broker = "wss://broker.hivemq.com:8884/mqtt";
const options = {
  clientId: "web_" + Math.random().toString(16).substr(2, 8)
};

const client = mqtt.connect(broker, options);

/* ===== MQTT 連線 ===== */
client.on("connect", () => {
  console.log("MQTT 已連線");
  client.subscribe("esp32/dht/#");
  client.subscribe("esp32/led/state");
});

/* ===== 接收資料 ===== */
client.on("message", (topic, message) => {
  const data = message.toString();

  if (topic === "esp32/dht/temp") {
    document.getElementById("temp").innerText = data;
  }
  if (topic === "esp32/dht/hum") {
    document.getElementById("hum").innerText = data;
  }
  if (topic === "esp32/led/state") {
    document.getElementById("ledState").innerText = data.toUpperCase();
  }
});

/* ===== LED 控制 ===== */
function setLED(state) {
  client.publish("esp32/led/set", state);
}
</script>

</body>
</html>
